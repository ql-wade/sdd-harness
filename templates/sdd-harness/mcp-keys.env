# MCP Keys — SDD Harness 的 MCP auth/endpoint 统一管理
# 由 sdd init 生成模板到 ~/.sdd/mcp-keys.env
# 不写进 config.yaml（防止 key 进 git）
# 跨 worktree 共享（symlink 或 copy 自主仓 ~/.sdd/）

# === 必填（缺少则对应 stage 不可用） ===

# LLMWiki MCP（test + archive 阶段共用）
LLMWIKI_ENDPOINT=
LLMWIKI_API_KEY=

# === 按需 ===

# Playwright MCP（verify 阶段功能 E2E）
# 通常走本地 chromium，无需 key

# chrome-devtools MCP（verify 阶段非功能审计）
# 通常走本地 Chrome DevTools Protocol，无需 key

# GitHub MCP（optional，issue/PR/CI 集成）
GITHUB_TOKEN=

# === SDD Harness 自带 MCP（本地，无需 key） ===
# sdd-context-mcp: 聚合本地文件 + OpenSpec + git diff + LLMWiki
# understand-anything-mcp: 只读 .understand-anything/knowledge-graph.json
# openspec-sdd-mcp: Phase 8 封装 openspec/trinity CLI
